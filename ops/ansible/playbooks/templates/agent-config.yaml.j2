# Platform contract: dev mode uses dev_ws_token over ws; production bootstrap
# uses registration_token followed by certificates over wss+mTLS.
server_id: {{ server_id }}
control_plane: {{ control_plane_url | to_json }}
cert_file: /etc/pressluft/agent.crt
key_file: /etc/pressluft/agent.key
ca_cert_file: /etc/pressluft/ca.crt
data_dir: /var/lib/pressluft
registration_token: {{ registration_token | default('') | to_json }}
dev_ws_token: {{ dev_ws_token | default('') | to_json }}
